todo_list = []

keep_adding = True
while keep_adding:
	
	new_task = input("Enter Your Task :")
	todo_list.append(new_task)
	print(f"Your Task {new_task} is added ")
	
	more_task = input("You  add more task? No/Yes :").lower()
	
	if more_task == ("no"):
		keep_adding = False

print("Your Final ToDo List")

index = 1
for task in todo_list:
	print(f"{index}.{task}")
	index += 1

delete_task = int(input("Enter Task Number To Delete : "))
delete_index = delete_task - 1
delete_task = todo_list.pop(delete_index)
print(f"Your {delete_task} deleted :")

print("Your Final ToDo List")

index = 1
for task in todo_list:
	print(f"{index}.{task}")
	index += 1
